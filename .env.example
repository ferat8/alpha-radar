# AlphaRadar Configuration
# Copy this to .env and fill in your values

# Your USDC wallet address on Base (receives payments)
# Example: 0xd8C967DdAb8765295d97de4f65a745cD3f2543E9
WALLET_ADDRESS=0x_YOUR_WALLET_ADDRESS

# Base RPC URL (get free at alchemy.com or infura.io)
RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Server port
PORT=3000

# Network: mainnet or testnet
NETWORK=mainnet

# Optional: The Graph API key for subgraph queries
GRAPH_API_KEY=
